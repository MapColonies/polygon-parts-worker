{
  "name": "polygon-parts-worker",
  "version": "2.2.0",
  "description": "worker service that handle the polygon parts different tasks",
  "main": "./src/index.ts",
  "scripts": {
    "test:unit": "jest --config=./tests/configurations/unit/jest.config.js",
    "test:integration": "jest --config=./tests/configurations/integration/jest.config.js",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "prelint:fix": "npm run format:fix",
    "prelint": "npm run format",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "release": "standard-version",
    "test": "tsc --noEmit && npm run test:unit && npm run test:integration",
    "prebuild": "npm run clean",
    "build": "tsc --project tsconfig.build.json && tsc-alias -p tsconfig.build.json && npm run assets:copy",
    "start": "npm run build && cd dist && node --import ./instrumentation.mjs ./index.js",
    "start:dev": "npm run build && cd dist && cross-env CONFIG_OFFLINE_MODE=true node --enable-source-maps --import ./instrumentation.mjs ./index.js",
    "assets:copy": "copyfiles -f ./config/* ./dist/config && copyfiles ./package.json dist",
    "clean": "rimraf dist",
    "install": "npx husky install"
  },
  "directories": {
    "test": "tests"
  },
  "author": "MapColonies",
  "license": "ISC",
  "husky": {
    "hooks": {
      "pre-commit": "pretty-quick --staged",
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS"
    }
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.943.0",
    "@aws-sdk/lib-storage": "^3.971.0",
    "@godaddy/terminus": "^4.12.1",
    "@map-colonies/config": "^4.0.1",
    "@map-colonies/error-types": "^1.3.1",
    "@map-colonies/js-logger": "^5.0.0",
    "@map-colonies/mc-model-types": "^17.13.0",
    "@map-colonies/mc-priority-queue": "^9.1.0",
    "@map-colonies/mc-utils": "^5.1.0",
    "@map-colonies/prometheus": "^1.0.0",
    "@map-colonies/raster-shared": "^8.3.0-alpha.0",
    "@map-colonies/read-pkg": "0.0.1",
    "@map-colonies/schemas": "^1.18.0",
    "@map-colonies/shapefile-reader": "^1.0.1",
    "@map-colonies/telemetry": "^6.0.0",
    "@map-colonies/tracing": "^1.0.0",
    "@map-colonies/tracing-utils": "^1.0.0",
    "@map-colonies/tsconfig": "^2.0.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/api-metrics": "0.33.0",
    "adm-zip": "^0.5.16",
    "archiver": "^7.0.1",
    "axios": "^1.13.4",
    "compression": "^1.7.4",
    "cross-env": "^10.1.0",
    "express": "^4.19.2",
    "http-status-codes": "^2.2.0",
    "lodash.get": "^4.4.2",
    "lodash.has": "^4.5.2",
    "ogr2ogr": "^5.1.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.1.13",
    "shapefile": "^0.6.6",
    "tsyringe": "^4.8.0",
    "uuid": "^11.1.0",
    "xmlbuilder2": "^4.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^17.6.6",
    "@faker-js/faker": "^9.9.0",
    "@map-colonies/eslint-config": "^7.2.0",
    "@map-colonies/prettier-config": "0.0.1",
    "@map-colonies/standard-version-update-helm-version": "^2.0.1",
    "@swc/jest": "^0.2.39",
    "@types/adm-zip": "^0.5.7",
    "@types/archiver": "^7.0.0",
    "@types/compression": "^1.7.2",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/lodash.get": "^4.4.9",
    "@types/lodash.has": "^4.5.9",
    "@types/mock-fs": "^4.13.4",
    "@types/multer": "^1.4.7",
    "@types/shapefile": "^0.6.4",
    "@types/supertest": "^2.0.12",
    "commitlint": "^17.6.6",
    "copyfiles": "^2.4.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^9.39.3",
    "eslint-plugin-jest": "^29.15.0",
    "husky": "^9.1.7",
    "jest": "^29.5.0",
    "jest-create-mock-instance": "^2.0.0",
    "jest-html-reporters": "^3.1.4",
    "lodash": "^4.17.21",
    "mock-fs": "^5.4.1",
    "nock": "^13.5.5",
    "prettier": "^3.8.1",
    "pretty-quick": "^4.2.2",
    "rimraf": "^6.1.2",
    "standard-version": "^9.5.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.0.5",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
